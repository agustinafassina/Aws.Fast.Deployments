# =============================================================================
# Sample environment variables for LOCAL use of the helper scripts.
#
# Copy this file to `.env` (which is git-ignored) and fill in the values, OR
# export these variables in your shell. In Azure DevOps these values come from
# the AWS service connection / pipeline variables instead (see pipelines/README.md).
#
# NEVER commit real credentials.
# =============================================================================

# --- AWS credentials (local only; in Azure DevOps use the AWS service connection) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Optional: use a named profile from ~/.aws/credentials instead of keys above
# AWS_PROFILE=my-deploy-profile

# --- Deployment behaviour ---
# Target environment for local deploy tests: staging | production
DEPLOY_ENV=staging

# Path to the central site config (defaults to config/sites.json)
SITES_CONFIG=config/sites.json

# Set to "true" to print actions without performing them
DRY_RUN=false
